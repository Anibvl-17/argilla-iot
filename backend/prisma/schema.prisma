generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER // Ceramistas
  ADMIN // Administrador del sistema
}

enum SwitchTypes {
  SSR
  CONTACTOR
}

enum CtrlOperativeStatus {
  ON
  OFF
}

model User {
  userId    Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  // Un usuario puede tener cero o varios hornos
  kilns Kiln[]

  // Un usuario puede tener cero o varios controladores
  controllers Controller[]
}

// Hardware físico (ESP32)
model Controller {
  controllerId    String              @id @default(uuid())
  operationStatus String              @default("OFF")
  pin             Int? // PIN temporal para vinculación
  operativeStatus CtrlOperativeStatus @default(OFF)
  switchType      SwitchTypes         @default(CONTACTOR)
  switchAmps      Int                 @default(20)

  // Controlador instalado en el horno
  userId Int?
  user   User? @relation(fields: [userId], references: [userId], onDelete: SetNull)

  // Un controlador maneja un horno a la vez
  kiln Kiln?
}

// Horno
model Kiln {
  kilnId Int    @id @default(autoincrement())
  name   String @default("Mi Horno Argillá")
  liters Int // Ej. 30, 40
  phases Int    @default(1) // 1 = monofasico, 3 = trifasico
  volts  Int    @default(220)
  amps   Int // Ej. 20, 25

  // Dueño del horno
  userId Int?
  user   User? @relation(fields: [userId], references: [userId], onDelete: SetNull)

  // Controlador instalado en el horno
  controllerId String?     @unique
  controller   Controller? @relation(fields: [controllerId], references: [controllerId], onDelete: SetNull)

  // Historial térmico (asociado al horno, si se cambia controlador no pasa nada)
  telemetry Telemetry[]
}

// Datos de telemetría
model Telemetry {
  telemetryId Int      @id @default(autoincrement())
  temperature Float
  switchState Boolean
  timestamp   DateTime @default(now())

  kilnId Int
  kiln   Kiln @relation(fields: [kilnId], references: [kilnId], onDelete: Cascade)
}
